      static void operadoresMatematicos() {
    	  int x = 10;
    	  int y = 3;
    	  System.out.println(x + y);
    	  System.out.println(x - y);
    	  System.out.println(x * y);
    	  System.out.println(x / y); //3,33
    	  System.out.println(x % y);
    	  System.out.println(x++);
    	  System.out.println(x);
    	  System.out.println(++y);
    	  System.out.println(--x);
    	  x = x + 1;
      }
